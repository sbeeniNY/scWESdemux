// nf-core/sarek config — TEMPLATE
// v4: 3 callers (DeepVariant + FreeBayes + HaplotypeCaller),
//     BQSR enabled, WES mode with an exome capture target BED.
//
// Replace every /path/to/... placeholder and the LSF project/queue below.
//
// Usage:
//   nextflow run nf-core/sarek -r 3.5.1 -profile singularity -c nextflow.config

params {
    input       = "${launchDir}/samplesheet.csv"
    outdir      = "/path/to/output/sarek_results"

    // Use the SAME (e.g. Cell Ranger GRCh38, chr-prefixed) reference as the
    // scRNA-seq BAMs for consistent chromosome naming.
    genome         = null
    igenomes_ignore = true
    fasta          = "/path/to/reference/refdata-gex-GRCh38-2024-A/fasta/genome.fa"

    // GATK known sites — used for BQSR and variant annotation
    dbsnp                = "/path/to/reference/GATK_bundle/Homo_sapiens_assembly38.dbsnp138.vcf"
    dbsnp_tbi            = "/path/to/reference/GATK_bundle/Homo_sapiens_assembly38.dbsnp138.vcf.idx"
    known_indels         = "/path/to/reference/GATK_bundle/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    known_indels_tbi     = "/path/to/reference/GATK_bundle/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz.tbi"
    known_snps           = "/path/to/reference/GATK_bundle/Homo_sapiens_assembly38.dbsnp138.vcf"
    known_snps_tbi       = "/path/to/reference/GATK_bundle/Homo_sapiens_assembly38.dbsnp138.vcf.idx"

    // Variant callers: 3 callers, take consensus in Part 2.
    // NOTE: mpileup/bcftools is intentionally excluded — bcftools call produces
    // malformed multi-allelic records against the Cell Ranger reference.
    tools              = "deepvariant,freebayes,haplotypecaller"

    // WES mode with an exome capture target BED (e.g. Twist Comprehensive Exome, hg38)
    wes                = true
    intervals          = "/path/to/reference/Twist_Comprehensive_Exome_Covered_Targets_hg38.bed"
}

// -- Executor: LSF (edit to match your scheduler) ----------------------------
process {
    executor       = 'lsf'
    queue          = 'premium'
    clusterOptions = '-P acc_YourProject'
    shell          = [
        'bash',
        '-C',
        '-e',
        '-u',
        '-o',
        'pipefail'
    ]
    resourceLimits = [
        cpus: 16,
        memory: 64.GB,
        time: 48.h
    ]

}

// -- Singularity / Apptainer -------------------------------------------------
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = "/path/to/containers/singularity_cache"
}

// -- Nextflow settings -------------------------------------------------------
cleanup = true
